APP_NAME=Overcloud
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080

APP_LOCALE=es
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=sqlite
DB_DATABASE=/app/database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public

MAIL_MAILER=log

# WhatsApp gateway is not reachable from the demo instance; calls fail gracefully.
WA_GATEWAY_URL=http://127.0.0.1:8088
WA_GATEWAY_TOKEN=disabled
ANTHROPIC_API_KEY=
AI_ENABLED=false
COMPANY_NAME=Overcloud
